rules_version = '2';
// Regras Firestore – necessário para gravação direta do cliente (quando API Admin não está disponível)
// Em Firebase Console → Firestore → Rules, colar e publicar.
service cloud.firestore {
  match /databases/{database}/documents {
    match /config/{document=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /servicos/{document=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /marcacoes/{document=**} {
      allow read: if request.auth != null;
      allow create: if true;
      allow update, delete: if request.auth != null;
    }
    match /categorias_inventario/{document=**} {
      allow read, write: if request.auth != null;
    }
    match /itens_inventario/{document=**} {
      allow read, write: if request.auth != null;
    }
    match /movimentos_inventario/{document=**} {
      allow read, write: if request.auth != null;
    }
    match /categorias_custos/{document=**} {
      allow read, write: if request.auth != null;
    }
    match /custos_mensais/{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
